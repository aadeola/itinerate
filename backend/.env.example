# Point the Java backend at the local Cursor proxy (see llm-proxy/)
ITINERARY_LLM_API_KEY=local
ITINERARY_LLM_BASE_URL=http://localhost:8081/v1
ITINERARY_LLM_MODEL=composer-2.5

# Screenshot-to-activity vision feature (Google Gemini via Google AI Studio).
# Get a key at https://aistudio.google.com/app/apikey
ITINERARY_VISION_API_KEY=your_google_ai_studio_key_here
ITINERARY_VISION_BASE_URL=https://generativelanguage.googleapis.com
ITINERARY_VISION_MODEL=gemini-2.5-flash
ITINERARY_VISION_MAPS_RESOLVE_URL=http://localhost:8081/v1/maps/resolve

# Itinerary map — Google Geocoding REST API.
# Use the same key as GOOGLE_MAPS_API_KEY in llm-proxy/.env.
# Requires: (1) Geocoding API enabled, (2) billing account linked to the GCP project
# (Google requires billing even for the free $200/month Maps credit).
ITINERARY_GEOCODING_API_KEY=your_google_maps_api_key_here
